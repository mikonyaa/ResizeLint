  "multiline": "let window = UIApplication\n    .shared\n    .connectedScenes\n    .first",
  "conditional": "#if canImport(UIKit)\nlet window = UIApplication.shared.windows.first\n#endif",
  "suppression": "// resizelint:disable-next-line RL004 -- Test harness controls the only scene.\nlet window = UIApplication.shared.keyWindow",
  "expected": { "severity": "error", "messageContains": "scene-specific", "count": 1 }
}
